\newlabel{fig:sub_de}{{2a}{11}{Toy Example: The Global Minimiser}{subfigure.2.1}{}}
\newlabel{fig:sub_dle}{{2b}{11}{Toy Example: The Global Minimiser}{subfigure.2.2}{}}
\newlabel{fig:sub_drle}{{2c}{11}{Toy Example: The Global Minimiser}{subfigure.2.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Particle distributions after 100,000 steps across three regularisation regimes. \textbf  {(a)} Driven solely by gradient descent, unregularised particles collapse entirely into point masses at the local and global minima. \textbf  {(b)} The injection of noise allows particles to escape strict collapse and sample from the optimal Gibbs posterior. \textbf  {(c)} Adding a repulsive kernel forces particles away from one another, resulting in a broader, flatter distribution that ensures more diverse coverage of the parameter space.}}{11}{figure.caption.9}\protected@file@percent }
\newlabel{fig:ensemble_progression}{{2}{11}{Particle distributions after 100,000 steps across three regularisation regimes. \textbf {(a)} Driven solely by gradient descent, unregularised particles collapse entirely into point masses at the local and global minima. \textbf {(b)} The injection of noise allows particles to escape strict collapse and sample from the optimal Gibbs posterior. \textbf {(c)} Adding a repulsive kernel forces particles away from one another, resulting in a broader, flatter distribution that ensures more diverse coverage of the parameter space}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {subfigure}{\numberline{(a)}{\ignorespaces {DE ($\lambda _1 = 0, \lambda _2 = 0$)}}}{11}{subfigure.2.1}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(b)}{\ignorespaces {DLE ($\lambda _1 = 0, \lambda _2 = 1$)}}}{11}{subfigure.2.2}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(c)}{\ignorespaces {DRLE ($\lambda _1 = 1.0, \lambda _2 = 1$)}}}{11}{subfigure.2.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Quantitative impact of the repulsive regularisation parameter $\lambda _1$. As the repulsive force increases, probability mass systematically redistributes between basins, peak heights decrease, and the overall standard deviation widens. This increased particle diversity comes at the explicit cost of an expanding Kullback-Leibler (KL) divergence from the standard Deep Langevin Ensemble target.}}{11}{figure.caption.10}\protected@file@percent }
\newlabel{fig:comparison}{{3}{11}{Quantitative impact of the repulsive regularisation parameter $\lambda _1$. As the repulsive force increases, probability mass systematically redistributes between basins, peak heights decrease, and the overall standard deviation widens. This increased particle diversity comes at the explicit cost of an expanding Kullback-Leibler (KL) divergence from the standard Deep Langevin Ensemble target}{figure.caption.10}{}}
